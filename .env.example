# Public site settings
NEXT_PUBLIC_SITE_URL=https://safartraders.com
NEXT_PUBLIC_CONTACT_EMAIL=thesafartraders@gmail.com

# Chat assistant provider (OpenRouter — https://openrouter.ai/keys)
OPENROUTER_API_KEY=
