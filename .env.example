# Optional WhatsApp Cloud API delivery for RFQ PDFs
# If these are empty, the site falls back to a manual WhatsApp share link.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_RECIPIENT=+917540002039
WHATSAPP_BUYER_TEMPLATE_NAME=rfq_summary_confirmation
